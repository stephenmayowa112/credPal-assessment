# Server Configuration
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/fx_trading_db

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=FX Trading Platform

# Application Configuration
APP_NAME=FX Trading Platform
APP_URL=https://trading.example.com

# External API Configuration
FX_API_URL=https://api.exchangerate-api.com/v4/latest
